<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Coordinación Domicilios LACE</title>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root { --verde: #00913f; --verde-oscuro: #006e30; --verde-claro: #e8f5ee; --verde-borde: #b2dcc2; }
body { font-family: system-ui, sans-serif; background: #f4f6f4; min-height: 100vh; color: #1a1a1a; }

.topbar { background: var(--verde); padding: 14px 1.25rem; display: flex; align-items: center; justify-content: space-between; }
.topbar-text h1 { font-size: 16px; font-weight: 600; color: white; }
.topbar-text p { font-size: 12px; color: rgba(255,255,255,0.8); margin-top: 1px; }
.btn-refresh { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4); color: white; padding: 6px 14px; border-radius: 6px; font-size: 13px; cursor: pointer; font-family: inherit; }
.btn-refresh:hover { background: rgba(255,255,255,0.3); }

.fecha-bar { background: var(--verde-oscuro); padding: 8px 1.25rem; }
.fecha-bar span { font-size: 13px; color: rgba(255,255,255,0.85); }
.fecha-bar strong { color: white; }

.resumen-bar { background: white; border-bottom: 1px solid #dde8e1; padding: 10px 1.25rem; display: flex; gap: 1.5rem; align-items: center; flex-wrap: wrap; }
.resumen-item { display: flex; flex-direction: column; }
.resumen-item span:first-child { font-size: 10px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; }
.resumen-item span:last-child { font-size: 18px; font-weight: 700; color: var(--verde-oscuro); }

.filtros { padding: 0.75rem 1.25rem; background: white; border-bottom: 1px solid #dde8e1; display: flex; gap: 8px; flex-wrap: wrap; }
.filtro-btn { padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; cursor: pointer; border: 1px solid #ccddd4; background: white; color: #555; font-family: inherit; transition: all 0.15s; }
.filtro-btn.activo { background: var(--verde); color: white; border-color: var(--verde); }
.filtro-btn:hover { border-color: var(--verde); color: var(--verde); }

.container { padding: 1rem 1.25rem; max-width: 1000px; margin: 0 auto; }
.loading { text-align: center; padding: 3rem; color: #888; font-size: 14px; }
.empty { text-align: center; padding: 3rem; color: #888; }

.paciente-card { background: white; border: 1px solid #dde8e1; border-radius: 12px; margin-bottom: 0.75rem; overflow: hidden; }
.paciente-card.tiene-novedad { border-left: 4px solid #f0ad00; }

.card-header { background: var(--verde-claro); padding: 10px 16px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid var(--verde-borde); flex-wrap: wrap; }
.card-num { width: 26px; height: 26px; background: var(--verde); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; flex-shrink: 0; }
.card-nombre { font-size: 14px; font-weight: 600; color: var(--verde-oscuro); flex: 1; min-width: 150px; }
.card-equipo { font-size: 11px; font-weight: 600; background: var(--verde); color: white; padding: 3px 10px; border-radius: 20px; }
.card-dni { font-size: 12px; color: #666; background: white; border: 1px solid var(--verde-borde); border-radius: 5px; padding: 2px 8px; }

.card-body { padding: 12px 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
@media (max-width: 600px) { .card-body { grid-template-columns: 1fr; } }

.info-cell { display: flex; flex-direction: column; gap: 2px; }
.info-cell.full { grid-column: 1 / -1; }
.info-label { font-size: 10px; font-weight: 600; color: var(--verde-oscuro); text-transform: uppercase; letter-spacing: 0.05em; }
.info-value { font-size: 13px; color: #333; line-height: 1.4; }
.info-value a { color: var(--verde); text-decoration: none; font-weight: 500; }

.costos-row { display: flex; gap: 1rem; flex-wrap: wrap; }
.costo-item { display: flex; flex-direction: column; gap: 1px; }
.costo-item span:first-child { font-size: 10px; color: #888; text-transform: uppercase; }
.costo-item span:last-child { font-size: 14px; font-weight: 600; color: #333; }

.horario-badge { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; background: var(--verde-claro); border: 1px solid var(--verde-borde); border-radius: 6px; font-size: 13px; font-weight: 600; color: var(--verde-oscuro); }
.horario-pendiente { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; background: #fff8e1; border: 1px solid #ffe082; border-radius: 6px; font-size: 12px; color: #856404; }

.novedad-box { background: #fff8e1; border: 1px solid #ffe082; border-radius: 8px; padding: 10px 12px; }
.novedad-box .info-label { color: #856404; }
.novedad-box .info-value { color: #5d4037; font-weight: 500; }

.divider-v { width: 1px; background: #f0f5f2; }
</style>
</head>
<body>

<div class="topbar">
  <div class="topbar-text">
    <h1>LACE Laboratorios — Coordinación</h1>
    <p>Vista del operador · Todos los equipos</p>
  </div>
  <button class="btn-refresh" onclick="cargarDatos()">↻ Actualizar</button>
</div>

<div class="fecha-bar">
  <span>Agenda de hoy: <strong id="fecha-hoy"></strong></span>
</div>

<div class="resumen-bar" id="resumen-bar"></div>

<div class="filtros" id="filtros-bar">
  <button class="filtro-btn activo" onclick="filtrar('todos', this)">Todos</button>
  <button class="filtro-btn" onclick="filtrar('Domislab', this)">Domislab</button>
  <button class="filtro-btn" onclick="filtrar('Zona Calera', this)">Zona Calera</button>
  <button class="filtro-btn" onclick="filtrar('Zona VCP', this)">Zona VCP</button>
  <button class="filtro-btn" onclick="filtrar('Villa María', this)">Villa María</button>
  <button class="filtro-btn" onclick="filtrar('Oncativo', this)">Oncativo</button>
  <button class="filtro-btn" onclick="filtrar('Villa Dolores', this)">Villa Dolores</button>
  <button class="filtro-btn" onclick="filtrar('Río Cuarto', this)">Río Cuarto</button>
  <button class="filtro-btn" onclick="filtrar('LACE', this)">LACE</button>
  <button class="filtro-btn" onclick="filtrar('novedad', this)" style="border-color:#ffe082;color:#856404;">⚠️ Con novedad</button>
</div>

<div class="container">
  <div id="contenido" class="loading">Cargando agenda de hoy...</div>
</div>

<script>
const CSV_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQyx7t0Olo9ZISOg42JMbb27-GEOL7CBICIRKLqqO9TB56tJ1hhVu5toxdNM9kscWiU34YpFTnw6NSG/pub?gid=0&single=true&output=csv';

let todosLosPacientes = [];
let filtroActivo = 'todos';

function hoy() {
  return new Date().toISOString().split('T')[0];
}

function formatFecha(iso) {
  const [y,m,d] = iso.split('-');
  const meses = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
  return `${parseInt(d)} de ${meses[parseInt(m)-1]} de ${y}`;
}

function parseCSV(text) {
  const lines = text.split('\n');
  const headers = lines[0].split(',').map(h => h.replace(/"/g,'').trim());
  return lines.slice(1).filter(l => l.trim()).map(line => {
    const vals = [];
    let cur = '', inQ = false;
    for (let c of line) {
      if (c === '"') inQ = !inQ;
      else if (c === ',' && !inQ) { vals.push(cur.trim()); cur = ''; }
      else cur += c;
    }
    vals.push(cur.trim());
    const obj = {};
    headers.forEach((h,i) => obj[h] = (vals[i]||'').replace(/^"|"$/g,''));
    return obj;
  });
}

function filtrar(equipo, btn) {
  filtroActivo = equipo;
  document.querySelectorAll('.filtro-btn').forEach(b => b.classList.remove('activo'));
  btn.classList.add('activo');
  renderPacientes();
}

function renderPacientes() {
  const contenido = document.getElementById('contenido');
  let pacientes = todosLosPacientes;
  if (filtroActivo === 'novedad') {
    pacientes = pacientes.filter(p => p['Novedad bioquímico'] && p['Novedad bioquímico'].trim());
  } else if (filtroActivo !== 'todos') {
    pacientes = pacientes.filter(p => p['Equipo'] === filtroActivo);
  }

  if (pacientes.length === 0) {
    contenido.innerHTML = '<div class="empty"><p>No hay pacientes para este filtro.</p></div>';
    return;
  }

  let html = '';
  pacientes.forEach((p, i) => {
    const tieneNovedad = p['Novedad bioquímico'] && p['Novedad bioquímico'].trim();
    const horario = p['Horario asignado'] && p['Horario asignado'].trim();
    const costoTotal = (parseFloat(p['Costo servicio'])||0) + (parseFloat(p['Coseguro'])||0) + (parseFloat(p['Estudios no cubiertos'])||0);

    html += `<div class="paciente-card ${tieneNovedad ? 'tiene-novedad' : ''}">
      <div class="card-header">
        <div class="card-num">${i+1}</div>
        <span class="card-nombre">${p['Apellido y nombre'] || '—'}</span>
        <span class="card-equipo">${p['Equipo'] || '—'}</span>
        <span class="card-dni">DNI ${p['DNI'] || '—'}</span>
      </div>
      <div class="card-body">
        <div class="info-cell">
          <span class="info-label">Teléfono</span>
          <span class="info-value"><a href="tel:${p['Teléfono']}">${p['Teléfono'] || '—'}</a></span>
        </div>
        <div class="info-cell">
          <span class="info-label">Horario asignado</span>
          <span class="info-value">
            ${horario
              ? `<span class="horario-badge">✓ ${horario}</span>`
              : `<span class="horario-pendiente">⏳ Pendiente</span>`}
          </span>
        </div>
        <div class="info-cell full">
          <span class="info-label">Dirección</span>
          <span class="info-value">${p['Dirección'] || '—'}${p['Link Google Maps'] ? ` <a href="${p['Link Google Maps']}" target="_blank">📍 Maps</a>` : ''}${p['Referencia adicional'] ? ` · ${p['Referencia adicional']}` : ''}</span>
        </div>
        <div class="info-cell full">
          <span class="info-label">Estudios solicitados</span>
          <span class="info-value">${p['Estudios solicitados'] || '—'}</span>
        </div>
        <div class="info-cell full">
          <span class="info-label">Costos</span>
          <span class="info-value">
            <div class="costos-row">
              <div class="costo-item"><span>Servicio</span><span>$${parseFloat(p['Costo servicio']||0).toLocaleString('es-AR')}</span></div>
              ${parseFloat(p['Coseguro']||0) > 0 ? `<div class="costo-item"><span>Coseguro</span><span>$${parseFloat(p['Coseguro']).toLocaleString('es-AR')}</span></div>` : ''}
              ${parseFloat(p['Estudios no cubiertos']||0) > 0 ? `<div class="costo-item"><span>No cubiertos</span><span>$${parseFloat(p['Estudios no cubiertos']).toLocaleString('es-AR')}</span></div>` : ''}
              <div class="costo-item"><span>Total</span><span style="color:var(--verde-oscuro);">$${costoTotal.toLocaleString('es-AR')}</span></div>
            </div>
          </span>
        </div>
        ${tieneNovedad ? `<div class="info-cell full"><div class="novedad-box"><span class="info-label">⚠️ Novedad del bioquímico</span><p class="info-value" style="margin-top:4px;">${p['Novedad bioquímico']}</p></div></div>` : ''}
      </div>
    </div>`;
  });
  contenido.innerHTML = html;
}

async function cargarDatos() {
  document.getElementById('contenido').innerHTML = '<div class="loading">Cargando...</div>';
  const fechaHoy = hoy();
  document.getElementById('fecha-hoy').textContent = formatFecha(fechaHoy);

  try {
    const resp = await fetch(CSV_URL + '&t=' + Date.now());
    const text = await resp.text();
    const rows = parseCSV(text);
    todosLosPacientes = rows.filter(r => r['Fecha'] === fechaHoy);

    // Resumen
    const total = todosLosPacientes.length;
    const conHorario = todosLosPacientes.filter(p => p['Horario asignado'] && p['Horario asignado'].trim()).length;
    const conNovedad = todosLosPacientes.filter(p => p['Novedad bioquímico'] && p['Novedad bioquímico'].trim()).length;
    document.getElementById('resumen-bar').innerHTML = `
      <div class="resumen-item"><span>Total hoy</span><span>${total}</span></div>
      <div class="resumen-item"><span>Con horario</span><span>${conHorario}</span></div>
      <div class="resumen-item"><span>Sin horario</span><span style="color:${total-conHorario > 0 ? '#856404' : 'inherit'}">${total - conHorario}</span></div>
      <div class="resumen-item"><span>Con novedad</span><span style="color:${conNovedad > 0 ? '#c0392b' : 'inherit'}">${conNovedad}</span></div>
    `;

    renderPacientes();
  } catch(e) {
    document.getElementById('contenido').innerHTML = '<div class="empty"><p>No se pudo cargar la agenda. Verificá la conexión.</p></div>';
  }
}

cargarDatos();
</script>
</body>
</html>